{
  "manifest_version": 3,
  "name": "Dobby AI",
  "version": "2.1.0",
  "description": "Select text and get instant AI explanations inline on any page",
  "permissions": ["contextMenus", "activeTab", "storage", "notifications"],
  "host_permissions": [
    "https://dobby-ai-proxy.zhongnansu.workers.dev/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["detection.js", "presets.js", "prompt.js", "history.js", "api.js", "bubble.js", "trigger.js", "content.js"]
  }],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
